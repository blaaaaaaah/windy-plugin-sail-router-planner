{
    "name": "windy-plugin-sail-router-planner",
    "version": "0.9.0",
    "description": "Windy plugin for sail route planning and optimization",
    "main": "dist/plugin.min.js",
    "type": "module",
    "scripts": {
        "build": "rm -rf dist && mkdir dist && SERVE=false rollup -c && cp package.json dist/",
        "build:win": "rmdir /s /q dist && mkdir dist && set SERVE=false && rollup -c && copy package.json dist\\",
        "start": "rollup -w -c",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/blaaaaaaah/windy-plugin-sail-router-planner.git"
    },
    "keywords": [
        "windy",
        "windy.com",
        "plugins",
        "sailing"
    ],
    "author": "Thomas Dubois",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/blaaaaaaah/windy-plugin-sail-router-planner/issues"
    },
    "homepage": "https://github.com/blaaaaaaah/windy-plugin-sail-router-planner",
    "dependencies": {
        "@windycom/plugin-devtools": "^3.0.3"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "jest": "^30.2.0",
        "ts-jest": "^29.4.6",
        "typescript": "^5.9.3"
    }
}
